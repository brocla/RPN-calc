# Normalize all text files to LF in the repo
* text=auto eol=lf

# Kotlin and build files
*.kt        text eol=lf
*.kts       text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
*.pro       text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Shell script must be LF
gradlew     text eol=lf

# Windows batch file must be CRLF
gradlew.bat text eol=crlf

# Binary files — no conversion
*.webp      binary
*.png       binary
*.jpg       binary
*.jar       binary
*.keystore  binary
